# ── Supabase ──────────────────────────────────────────────────────────
# Supabase project URL + service role key (NOT the anon key — server only)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── Email (rewards system) ────────────────────────────────────────────
GMAIL_PASS=your_gmail_app_password
ADMIN_EMAIL=admin@example.com

# ── Recharge / Shopify (rewards system) ───────────────────────────────
RECHARGE_API_TOKEN=sk_1x1_your_token
RECHARGE_WEBHOOK_SECRET=your_recharge_webhook_secret
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_your_token

# ── Anthropic (AI scoring) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key

# ── Klaviyo ───────────────────────────────────────────────────────────
KLAVIYO_API_KEY=your_klaviyo_key

# ── Cron auth ─────────────────────────────────────────────────────────
CRON_SECRET=your_cron_secret
