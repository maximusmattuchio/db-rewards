<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>One Cycle Away — Dirty Bastard</title>
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@700&family=Barlow:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body style="margin:0;padding:0;background:#E8E0D4;font-family:'Barlow',Arial,sans-serif;">

<!--[if !mso]><!-->
<!-- PREVIEW TEXT -->
<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;">Your {{ event.next_milestone_name }} is right there. One more charge and it's yours.&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;</div>
<!--<![endif]-->

<!-- Calculate progress bar percentage dynamically -->
<!-- Formula: cycle_count / (cycle_count + 1) * 100 — since cycles_to_next = 1 -->
{% assign next_cycle = event.cycle_count | plus: 1 %}
{% assign bar_pct = event.cycle_count | times: 100 | divided_by: next_cycle %}

<table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#E8E0D4;padding:48px 16px;">
  <tr>
    <td align="center">
      <table width="580" cellpadding="0" cellspacing="0" border="0" style="max-width:580px;width:100%;background:#F5EFE6;border-radius:4px;overflow:hidden;box-shadow:0 8px 40px rgba(13,59,35,0.18);">

        <!-- AMBER TOP BAR -->
        <tr>
          <td style="background:#C4733A;padding:10px 40px;text-align:center;">
            <span style="font-family:'Barlow',Arial,sans-serif;font-size:11px;font-weight:700;letter-spacing:4px;text-transform:uppercase;color:#0D3B23;">The Bastard Club</span>
          </td>
        </tr>

        <!-- HEADER -->
        <tr>
          <td style="background:#0D3B23;padding:48px 40px 40px 40px;text-align:center;">
            <h1 style="margin:0;font-family:'Oswald','Impact','Arial Black',Arial,sans-serif;font-size:52px;font-weight:700;color:#F5EFE6;text-transform:uppercase;letter-spacing:2px;line-height:1;">Don't Quit Now.</h1>
            <p style="margin:12px 0 0 0;font-family:'Barlow',Arial,sans-serif;font-size:16px;color:rgba(245,239,230,0.65);letter-spacing:1px;">You're one cycle away.</p>
          </td>
        </tr>

        <!-- AMBER DIVIDER -->
        <tr>
          <td style="background:#C4733A;height:3px;font-size:0;">&nbsp;</td>
        </tr>

        <!-- BODY -->
        <tr>
          <td style="padding:44px 40px 0 40px;">
            <p style="margin:0 0 16px 0;font-family:'Barlow',Arial,sans-serif;font-size:17px;font-weight:700;color:#0D3B23;line-height:1.5;">{% if person.first_name %}{{ person.first_name }}{% else %}One more{% endif %}. That's it.</p>
            <p style="margin:0 0 16px 0;font-family:'Barlow',Arial,sans-serif;font-size:15px;color:#4A3C30;line-height:1.8;">You're at <strong>{{ event.cycle_count }} cycles</strong>. One more charge and your <strong>{{ event.next_milestone_name }}</strong> is yours. No action needed — just let your subscription run.</p>
            <p style="margin:0;font-family:'Barlow',Arial,sans-serif;font-size:15px;color:#4A3C30;line-height:1.8;">You've come this far. Don't be that guy who cancels one cycle short.</p>
          </td>
        </tr>

        <!-- PROGRESS BAR -->
        <tr>
          <td style="padding:28px 40px 0 40px;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="background:#ffffff;border-radius:4px;padding:20px 24px;">
                  <p style="margin:0 0 12px 0;font-family:'Barlow',Arial,sans-serif;font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#C4733A;">Your Progress</p>
                  <!-- PROGRESS BAR TRACK -->
                  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:10px;">
                    <tr>
                      <td style="background:#E8E0D4;border-radius:99px;height:10px;overflow:hidden;padding:0;">
                        <table width="100%" cellpadding="0" cellspacing="0" border="0">
                          <tr>
                            <td width="{{ bar_pct }}%" style="background:#C4733A;height:10px;border-radius:99px;"></td>
                            <td></td>
                          </tr>
                        </table>
                      </td>
                    </tr>
                  </table>
                  <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                      <td style="font-family:'Barlow',Arial,sans-serif;font-size:12px;color:#A09080;">{{ event.cycle_count }} cycles complete</td>
                      <td align="right" style="font-family:'Barlow',Arial,sans-serif;font-size:12px;font-weight:700;color:#C4733A;">1 away 🔥</td>
                    </tr>
                  </table>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- NEXT MILESTONE CARD -->
        <tr>
          <td style="padding:20px 40px 0 40px;">
            <table width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="background:#0D3B23;border-radius:4px;padding:22px 28px;">
                  <table width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                      <td>
                        <p style="margin:0 0 4px 0;font-family:'Barlow',Arial,sans-serif;font-size:10px;color:#C4733A;text-transform:uppercase;letter-spacing:3px;font-weight:700;">Next Reward</p>
                        <p style="margin:0;font-family:'Oswald','Impact','Arial Black',Arial,sans-serif;font-size:22px;font-weight:700;color:#F5EFE6;text-transform:uppercase;letter-spacing:1px;">{{ event.next_milestone_name }}</p>
                      </td>
                      <td align="right" style="font-size:36px;padding-left:16px;">🏆</td>
                    </tr>
                  </table>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- CTA -->
        <tr>
          <td style="padding:36px 40px 0 40px;text-align:center;">
            <a href="https://getdirtybastard.com/pages/rewards?utm_source=klaviyo&utm_medium=email&utm_campaign=bastard-club-one-cycle-away&utm_content=cta" style="display:inline-block;background:#C4733A;color:#0D3B23;padding:16px 44px;border-radius:4px;text-decoration:none;font-family:'Barlow',Arial,sans-serif;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;">View Your Rewards →</a>
          </td>
        </tr>

        <!-- SIGN OFF -->
        <tr>
          <td style="padding:36px 40px 44px 40px;">
            <p style="margin:0;font-family:'Barlow',Arial,sans-serif;font-size:15px;color:#4A3C30;line-height:1.8;">Keep washing.<br><strong style="color:#0D3B23;">— Dirty Bastard</strong></p>
          </td>
        </tr>

        <!-- FOOTER -->
        <tr>
          <td style="background:#0A2415;padding:32px 40px;text-align:center;">
            <p style="margin:0 0 6px 0;font-family:'Barlow',Arial,sans-serif;font-size:12px;color:rgba(245,239,230,0.45);">Questions? <a href="mailto:hello@getdirtybastard.com" style="color:#C4733A;text-decoration:none;font-weight:600;">hello@getdirtybastard.com</a></p>
            <p style="margin:0 0 6px 0;font-family:'Barlow',Arial,sans-serif;font-size:11px;color:rgba(245,239,230,0.25);">Dirty Bastard Laundry Co. · <a href="https://getdirtybastard.com?utm_source=klaviyo&utm_medium=email&utm_campaign=bastard-club-one-cycle-away" style="color:rgba(245,239,230,0.25);text-decoration:none;">getdirtybastard.com</a></p>
            <!-- CAN-SPAM: physical mailing address required. Replace with your PO Box or registered address. -->
            <p style="margin:0 0 16px 0;font-family:'Barlow',Arial,sans-serif;font-size:10px;color:rgba(245,239,230,0.18);">715 W Orient St · Tampa, FL</p>
            <p style="margin:0;font-family:'Barlow',Arial,sans-serif;font-size:10px;color:rgba(245,239,230,0.18);">You're receiving this because you give a sheet. <a href="{{ unsubscribe_url }}" style="color:rgba(245,239,230,0.18);text-decoration:underline;">Unsubscribe</a></p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>

</body>
</html>
